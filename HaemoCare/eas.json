{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "preview": {
      "distribution": "internal",
      "android": { "buildType": "apk" },
      "channel": "preview",
      "autoIncrement": "versionCode"
    },
    "production": {
      "android": { "buildType": "app-bundle" },
      "channel": "production",
      "autoIncrement": "versionCode"
    }
  },
  "submit": {
    "production": {}
  }
}
