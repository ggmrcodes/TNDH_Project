# Copy to .env and fill in with real values. `.env` is git-ignored.

# --- Supabase (real-auth mode) ---
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# --- Photo → transfusion AI extraction ---
# The Gemini API key lives SERVER-SIDE in Supabase Secrets and is read by
# the `extract-transfusion` Edge Function — it is NOT a client-side env var
# and never ships in the app bundle. To configure:
#   supabase secrets set GEMINI_API_KEY=AIza...
#   supabase functions deploy extract-transfusion
# Get a key at https://aistudio.google.com/apikey
#
# This flag below is a client-side kill-switch only (default enabled).
# Set to "false" in .env to disable client invocations (e.g. to avoid
# burning Gemini quota during demos / mock-mode work).
EXPO_PUBLIC_AI_EXTRACTION_ENABLED=true

# --- TH Core FHIR endpoint (hospital appointment integration) ---
# Point at any HAPI FHIR server seeded with the TH Core IG. Local demo setup:
#   docker run -d -p 8090:8080 hapiproject/hapi:latest
#   ./scripts/seed-fhir.sh
EXPO_PUBLIC_FHIR_BASE_URL=http://localhost:8090/fhir
EXPO_PUBLIC_FHIR_TEST_PATIENT_ID=Patient/haemocare-mock-patient

# --- Update manifest (native-version check) ---
# Override the URL where the app fetches its release manifest JSON.
# Default: https://raw.githubusercontent.com/ggmrcodes/TNDH_Project/main/update-manifest.json
EXPO_PUBLIC_UPDATE_MANIFEST_URL=
