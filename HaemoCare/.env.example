# Copy to .env and fill in with real values. `.env` is git-ignored.

# --- Supabase (real-auth mode) ---
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# --- Anthropic API (for photo → transfusion AI extraction) ---
# Hackathon / demo only — this key is bundled into the app.
# In production, proxy through a Supabase Edge Function instead.
# Get a key at https://console.anthropic.com/
EXPO_PUBLIC_ANTHROPIC_API_KEY=

# --- TH Core FHIR endpoint (hospital appointment integration) ---
# Point at any HAPI FHIR server seeded with the TH Core IG. Local demo setup:
#   docker run -d -p 8090:8080 hapiproject/hapi:latest
#   ./scripts/seed-fhir.sh
EXPO_PUBLIC_FHIR_BASE_URL=http://localhost:8090/fhir
EXPO_PUBLIC_FHIR_TEST_PATIENT_ID=Patient/haemocare-mock-patient
